# Copy to .env and adjust for your VPS:  cp .env.example .env
# docker compose -f docker-compose.prod.yml automatically reads .env

# Public HTTP port the frontend listens on (the site)
HTTP_PORT=80

# PostgreSQL
POSTGRES_DB=hrms
POSTGRES_USER=hrms
POSTGRES_PASSWORD=change-me-strong-password

# RabbitMQ
RABBITMQ_USER=hrms
RABBITMQ_PASSWORD=change-me

# MinIO (object storage)
MINIO_USER=hrms
MINIO_PASSWORD=change-me-12345

# JWT signing secret (MUST be >= 32 characters, random). Used to sign login tokens.
HRMS_JWT_SECRET=change-me-please-use-a-long-random-secret-key-32b+
